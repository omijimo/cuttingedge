<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Melody → Chords → Accompaniment (on-device TFLite)"
            android:textSize="14sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Melody selector -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_midi"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/melodySpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/selectableItemBackground" />

        <!-- Generate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/generateButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/run_inference"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_ready"
            android:textSize="14sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Timing info -->
        <TextView
            android:id="@+id/timingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Chords display -->
        <TextView
            android:id="@+id/chordsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/chords_label"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/chordsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Playback controls -->
        <LinearLayout
            android:id="@+id/playbackControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/playButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/play"
                style="@style/Widget.Material3.Button.TonalButton"
                app:cornerRadius="12dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stopButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/stop"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="12dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@color/on_surface_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_section_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_section_subtitle"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/realtimeUseMidiSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_use_midi_switch"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/realtimeBpmLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/realtime_bpm_hint"
            android:layout_marginBottom="10dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/realtimeBpmInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="120" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_key_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/realtimeKeySpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_mode_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/realtimeModeSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="?attr/selectableItemBackground" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_quantization_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/realtimeQuantSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:background="?attr/selectableItemBackground" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/realtimeLagLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/realtime_lag_hint"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/realtimeLagInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/realtimePlayPauseButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/realtime_play"
            style="@style/Widget.Material3.Button.TonalButton"
            app:cornerRadius="12dp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/realtimeStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_status_idle"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/realtimeNowPlayingLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_now_playing_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/realtimeNowPlayingChordText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/realtime_now_playing_chord_placeholder"
            android:textSize="13sp"
            android:textColor="@color/on_surface_secondary"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
